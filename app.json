{
  "expo": {
    "name": "Pacer",
    "slug": "pacer",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./frontend/images/High-Resolution-Color-Logo.png",
    "scheme": "pacer",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.fyprunningapp",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
  
    
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./frontend/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-web-browser",
      "expo-location",
      [
        "@rnmapbox/maps",
        {
          "RNMapboxMapsVersion": "11.17.1"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0a99394a-d5ae-4075-bc59-87949e38b717"
      }
    }
  }
}
