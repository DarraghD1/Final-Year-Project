{
  "expo": {
    "name": "fyp-running-app",
    "slug": "fyp-running-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./frontend/images/icon.png",
    "scheme": "fyprunningapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.fyprunningapp",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./frontend/images/android-icon-foreground.png",
        "backgroundImage": "./frontend/images/android-icon-background.png",
        "monochromeImage": "./frontend/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "package": "com.anonymous.fyprunningapp"
    },
    "web": {
      "output": "static",
      "favicon": "./frontend/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./frontend/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-web-browser",
      "expo-location",
      [
        "@rnmapbox/maps",
        {
          "RNMapboxMapsVersion": "11.17.1"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0a99394a-d5ae-4075-bc59-87949e38b717"
      }
    }
  }
}
